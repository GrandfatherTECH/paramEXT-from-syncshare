# Docker / Postgres
POSTGRES_DB=paramext
POSTGRES_USER=paramext
POSTGRES_PASSWORD=change_me_postgres

# Backend runtime
APP_ENV=production
DATABASE_MIN_CONNECTIONS=4
DATABASE_MAX_CONNECTIONS=40

# Optional public Bearer token for extension requests
# If empty, backend endpoints are available without Authorization header.
API_BEARER_TOKEN=

# Legacy API token alias (optional, fallback)
API_TOKEN=change_me_api_token

# Default extension API settings (used to prefill popup fields)
MOODLE_API_BASE_URL=https://syncshare.naloaty.me/api
MOODLE_API_TOKEN=
MOODLE_API_TIMEOUT_MS=4000
OPENEDU_API_BASE_URL=https://paramext.ruka.me/api
OPENEDU_API_TOKEN=
OPENEDU_API_TIMEOUT_MS=4000

# Admin dashboard auth token
ADMIN_TOKEN=change_me_admin_token

# Telegram forwarding for errors
TELEGRAM_BOT_TOKEN=123456:telegram_bot_token
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_TOPIC_ID=0
